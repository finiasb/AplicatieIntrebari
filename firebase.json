{
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
      { "source": "/elevi{,/**}", "destination": "/elevi/index.html" },
      { "source": "/profesor{,/**}", "destination": "/profesor/index.html" }
    ]
  }
}
